Bootstrap: docker
From: mefmri-pipeline:latest

%labels
  Author MultiEchofMRI-Pipeline-Beta
  Description Apptainer wrapper image for ME-fMRI pipeline

%environment
  export MEDIR=/opt/mefmri
  export HCPPIPEDIR=/opt/mefmri/HCPpipelines-master

%runscript
  exec /opt/mefmri/bin/mefmri_pipeline.sh "$@"
